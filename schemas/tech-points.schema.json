{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TechPoints",
  "type": "object",
  "required": ["schema_version", "role", "level", "points"],
  "properties": {
    "schema_version": { "type": "string" },
    "role": { "type": "string" },
    "level": { "type": "string", "enum": ["初级", "中级", "高级"] },
    "points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "topic", "scope", "primary_dimension", "evidence", "interview_value"],
        "properties": {
          "id": { "type": "string" },
          "topic": { "type": "string" },
          "scope": {
            "type": "string",
            "enum": ["frontend", "backend", "mobile", "infra", "fullstack"]
          },
          "primary_dimension": {
            "type": "string",
            "enum": ["feature", "architecture", "performance", "reliability", "observability", "trade-off", "security"]
          },
          "sub_project": { "type": "string" },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "depth_tags": { "type": "array", "items": { "type": "string" } },
          "interview_value": { "type": "string", "enum": ["低", "中", "高"] }
        }
      }
    }
  }
}
