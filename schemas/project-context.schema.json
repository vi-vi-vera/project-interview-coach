{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProjectContext",
  "type": "object",
  "required": ["schema_version", "platform_name", "sub_projects"],
  "properties": {
    "schema_version": { "type": "string" },
    "platform_name": { "type": "string" },
    "one_liner": { "type": "string" },
    "domain": { "type": "string" },
    "platform_tech_stack": {
      "type": "object",
      "properties": {
        "languages": { "type": "array", "items": { "type": "string" } },
        "frameworks": { "type": "array", "items": { "type": "string" } },
        "infra": { "type": "array", "items": { "type": "string" } }
      }
    },
    "sub_projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "scope"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "scope": {
            "type": "string",
            "enum": ["frontend", "backend", "mobile", "infra", "fullstack"]
          },
          "tech_stack": { "type": "object" },
          "modules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "responsibility"],
              "properties": {
                "name": { "type": "string" },
                "path": { "type": "string" },
                "responsibility": { "type": "string" }
              }
            }
          },
          "active_areas": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "highlights": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "scope", "summary"],
        "properties": {
          "title": { "type": "string" },
          "scope": {
            "type": "string",
            "enum": ["frontend", "backend", "mobile", "infra", "fullstack"]
          },
          "summary": { "type": "string" }
        }
      }
    }
  }
}
