{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InterviewData",
  "description": "Stage 3 output contract for project-interview-coach. Three modes share this schema; required fields branch by `mode` via if/then.",
  "type": "object",
  "required": ["schema_version", "mode", "platform_name"],
  "properties": {
    "schema_version": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["candidate", "interviewer", "knowledge", "study-guide"]
    },
    "platform_name": { "type": "string", "minLength": 1 },
    "role":  { "type": "string" },
    "level": { "type": "string" },

    "project_pitch": {
      "type": "object",
      "required": ["elevator", "standard", "deep_dive"],
      "properties": {
        "elevator":  { "$ref": "#/definitions/bilingual" },
        "standard":  { "$ref": "#/definitions/bilingual" },
        "deep_dive": { "$ref": "#/definitions/bilingual" }
      }
    },
    "highlights": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "scope", "primary_dimension", "story"],
        "properties": {
          "title":             { "type": "string" },
          "scope":             { "$ref": "#/definitions/scope" },
          "primary_dimension": { "$ref": "#/definitions/primaryDimension" },
          "story":             { "$ref": "#/definitions/bilingual" },
          "tech_keywords":     { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "qa": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/qaItem" }
    },
    "dimension_coverage": {
      "type": "object",
      "required": [
        "feature", "architecture", "performance",
        "reliability", "observability", "trade-off", "security"
      ],
      "additionalProperties": false,
      "properties": {
        "feature":       { "type": "integer", "minimum": 0 },
        "architecture":  { "type": "integer", "minimum": 0 },
        "performance":   { "type": "integer", "minimum": 0 },
        "reliability":   { "type": "integer", "minimum": 0 },
        "observability": { "type": "integer", "minimum": 0 },
        "trade-off":     { "type": "integer", "minimum": 0 },
        "security":      { "type": "integer", "minimum": 0 }
      }
    },

    "question_bank": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/interviewerQuestion" }
    },
    "rubrics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/rubric" }
    },

    "knowledge_map": {
      "type": "object",
      "required": ["topics"],
      "properties": {
        "topics": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/knowledgeTopic" }
        }
      }
    },

    "study_guide": {
      "type": "object",
      "required": ["phases", "clusters", "global_self_check", "tips"],
      "properties": {
        "phases": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["id", "theme", "cluster_ids"],
            "properties": {
              "id": { "type": "string", "pattern": "^[A-Z]$" },
              "theme": { "type": "string", "minLength": 2, "maxLength": 40 },
              "cluster_ids": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            }
          }
        },
        "clusters": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": [
              "id", "title", "scenario", "must_read",
              "hands_on", "self_check", "covered_topics"
            ],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string", "minLength": 2, "maxLength": 80 },
              "scenario": { "type": "string", "minLength": 6, "maxLength": 200 },
              "prerequisites": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": { "type": "string" },
                    "url": { "type": "string", "format": "uri" }
                  }
                }
              },
              "must_read": {
                "type": "array",
                "minItems": 2,
                "maxItems": 6,
                "items": {
                  "type": "object",
                  "required": ["title", "url"],
                  "properties": {
                    "title": { "type": "string" },
                    "url": { "type": "string", "format": "uri", "pattern": "^https?://" }
                  }
                }
              },
              "hands_on": {
                "type": "array",
                "minItems": 2,
                "maxItems": 4,
                "items": { "type": "string", "minLength": 8 }
              },
              "self_check": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": { "type": "string" }
              },
              "covered_topics": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            }
          }
        },
        "global_self_check": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["cluster_id", "question"],
            "properties": {
              "cluster_id": { "type": "string" },
              "question": { "type": "string" }
            }
          }
        },
        "tips": {
          "type": "array",
          "minItems": 4,
          "maxItems": 8,
          "items": { "type": "string", "minLength": 8 }
        }
      }
    }
  },

  "allOf": [
    {
      "if":   { "properties": { "mode": { "const": "candidate" } } },
      "then": { "required": ["project_pitch", "qa", "dimension_coverage"] }
    },
    {
      "if":   { "properties": { "mode": { "const": "interviewer" } } },
      "then": { "required": ["question_bank", "rubrics"] }
    },
    {
      "if":   { "properties": { "mode": { "const": "knowledge" } } },
      "then": { "required": ["knowledge_map"] }
    },
    {
      "if":   { "properties": { "mode": { "const": "study-guide" } } },
      "then": {
        "required": ["study_guide"],
        "not": {
          "anyOf": [
            { "required": ["qa"] },
            { "required": ["dimension_coverage"] },
            { "required": ["project_pitch"] },
            { "required": ["highlights"] },
            { "required": ["knowledge_map"] }
          ]
        }
      }
    }
  ],

  "definitions": {
    "scope": {
      "type": "string",
      "enum": ["frontend", "backend", "mobile", "infra", "fullstack"]
    },
    "primaryDimension": {
      "type": "string",
      "enum": [
        "feature", "architecture", "performance",
        "reliability", "observability", "trade-off", "security"
      ]
    },
    "knowledgeLevel": {
      "type": "string",
      "enum": ["必须掌握", "加分项"]
    },
    "depth": {
      "type": "string",
      "enum": ["初级", "中级", "高级"]
    },
    "bilingual": {
      "type": "object",
      "required": ["zh", "en"],
      "properties": {
        "zh": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    },
    "qaItem": {
      "type": "object",
      "required": [
        "id", "primary_dimension", "scope", "source_tech_point",
        "question", "answers", "knowledge_points", "learning_plan",
        "depth", "evidence"
      ],
      "properties": {
        "id":                { "type": "string" },
        "primary_dimension": { "$ref": "#/definitions/primaryDimension" },
        "scope":             { "$ref": "#/definitions/scope" },
        "sub_project":       { "type": "string" },
        "source_tech_point": { "type": "string" },
        "question":          { "$ref": "#/definitions/bilingual" },
        "answers": {
          "type": "object",
          "required": ["elevator", "standard", "deep_dive"],
          "properties": {
            "elevator":  { "$ref": "#/definitions/bilingual" },
            "standard":  { "$ref": "#/definitions/bilingual" },
            "deep_dive": { "$ref": "#/definitions/bilingual" }
          }
        },
        "knowledge_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "level", "why"],
            "properties": {
              "name":  { "type": "string", "minLength": 1 },
              "level": { "$ref": "#/definitions/knowledgeLevel" },
              "why":   { "type": "string", "minLength": 1 }
            }
          }
        },
        "learning_plan": {
          "type": "object",
          "required": [
            "must_read", "hands_on", "common_pitfalls",
            "mock_questions", "time_estimate"
          ],
          "properties": {
            "must_read":       { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "hands_on":        { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "common_pitfalls": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "mock_questions":  { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "time_estimate":   { "type": "string", "minLength": 1 }
          }
        },
        "follow_ups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["question", "primary_dimension", "expected_answer"],
            "properties": {
              "question":          { "$ref": "#/definitions/bilingual" },
              "primary_dimension": { "$ref": "#/definitions/primaryDimension" },
              "expected_answer":   { "$ref": "#/definitions/bilingual" }
            }
          }
        },
        "depth":    { "$ref": "#/definitions/depth" },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },

    "interviewerQuestion": {
      "type": "object",
      "required": [
        "id", "primary_dimension", "scope", "source_tech_point",
        "question", "depth", "evidence"
      ],
      "properties": {
        "id":                { "type": "string" },
        "primary_dimension": { "$ref": "#/definitions/primaryDimension" },
        "scope":             { "$ref": "#/definitions/scope" },
        "sub_project":       { "type": "string" },
        "source_tech_point": { "type": "string" },
        "question":          { "$ref": "#/definitions/bilingual" },
        "depth":             { "$ref": "#/definitions/depth" },
        "stress_probes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["question", "primary_dimension"],
            "properties": {
              "question":          { "$ref": "#/definitions/bilingual" },
              "primary_dimension": { "$ref": "#/definitions/primaryDimension" }
            }
          }
        },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },

    "rubric": {
      "type": "object",
      "required": ["qa_id", "criteria"],
      "properties": {
        "qa_id": { "type": "string" },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "weight", "indicators"],
            "properties": {
              "name":   { "type": "string", "minLength": 1 },
              "weight": { "type": "number", "minimum": 0, "maximum": 1 },
              "indicators": {
                "type": "object",
                "required": ["优秀", "合格", "不合格"],
                "properties": {
                  "优秀":   { "$ref": "#/definitions/bilingual" },
                  "合格":   { "$ref": "#/definitions/bilingual" },
                  "不合格": { "$ref": "#/definitions/bilingual" }
                }
              }
            }
          }
        }
      }
    },

    "knowledgeTopic": {
      "type": "object",
      "required": [
        "name", "level", "related_dimensions",
        "questions_using", "must_read", "hands_on"
      ],
      "properties": {
        "name":  { "type": "string", "minLength": 1 },
        "level": { "$ref": "#/definitions/knowledgeLevel" },
        "related_dimensions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/primaryDimension" }
        },
        "questions_using": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "must_read": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "hands_on":  { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
